# More info: https://docs.docker.com/engine/reference/builder/#dockerignore-file
# Ignore everything by default and re-include only the files needed to build
# the controller image.
**

# Re-include the Go module files.
!go.mod
!go.sum

# Re-include the source trees used by cmd/main.go.
!api/
!api/**
!cmd/
!cmd/**
!internal/
!internal/**

# Exclude tests from the Docker build context.
**/*_test.go
